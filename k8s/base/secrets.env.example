# Copy to k8s/base/secrets.env (gitignored) and fill in before
# `kubectl apply -k k8s/base`. Seven values (KUBERNETES_MODULE.md §6) -
# the five the compose .env holds plus the Postgres credentials compose
# hardcodes.

# Postgres superuser - consumed by the postgres StatefulSet AND (as
# SPRING_DATASOURCE_USERNAME/PASSWORD) by every DB-backed service.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-pg

# Must be identical for auth-service (signs) and api-gateway (verifies).
JWT_SECRET=change-me-to-a-long-random-string

# Gmail SMTP app password for notification-service. Placeholders are fine -
# the service starts and stays healthy; email sends just fail.
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=change-me

# checkin-service boarding-pass HMAC key.
CHECKIN_BOARDING_PASS_KEY=change-me-too

# Grafana admin login (kubectl port-forward svc/grafana 3001:3000).
GRAFANA_ADMIN_PASSWORD=change-me-three
