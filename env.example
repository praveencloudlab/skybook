# Copy this file to .env before running `docker compose up --build`.
# .env is gitignored - never commit real secrets.
#
# Every secret below is REQUIRED (SECURITY_HARDENING_MODULE.md §10): compose uses
# the ${VAR:?...} form, so an unset or empty value aborts `up`/`config` with a
# clear error instead of silently booting with a known-bad default.

# --- Database ---------------------------------------------------------------
# Postgres superuser password. Used by the postgres container AND every service's
# datasource (SPRING_DATASOURCE_PASSWORD). NOTE: only applied when the postgres
# data volume is first initialized - to change it later, recreate the volume.
POSTGRES_PASSWORD=change-me-postgres

# --- RS256 JWT keys (§5) -----------------------------------------------------
# auth-service signs with the PRIVATE key (sole holder); the gateway and every
# service verify with the PUBLIC key. Generate a keypair and paste the base64
# bodies as single lines (armor lines and newlines stripped):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#   openssl pkey -in jwt_private.pem -pubout -out jwt_public.pem
#   JWT_PRIVATE_KEY = grep -v '\-\-\-' jwt_private.pem | tr -d '\n'
#   JWT_PUBLIC_KEY  = grep -v '\-\-\-' jwt_public.pem  | tr -d '\n'
JWT_PRIVATE_KEY=paste-single-line-base64-pkcs8-private-key
JWT_PUBLIC_KEY=paste-single-line-base64-spki-public-key
# Environment-specific issuer/audience (default to skybook-auth / skybook-api).
JWT_ISSUER=skybook-auth
JWT_AUDIENCE=skybook-api
# Optional: promote this already-registered user to ADMIN once at startup.
SKYBOOK_BOOTSTRAP_ADMIN_EMAIL=

# --- Per-service client credentials (§3.3) ----------------------------------
# Secrets the booking/checkin/payment/inventory services use to obtain
# ROLE_SERVICE tokens; auth-service hashes the same values into its client
# registry. Generate each with e.g.  openssl rand -base64 32
BOOKING_SERVICE_CLIENT_SECRET=change-me-booking-secret
CHECKIN_SERVICE_CLIENT_SECRET=change-me-checkin-secret
PAYMENT_SERVICE_CLIENT_SECRET=change-me-payment-secret
INVENTORY_SERVICE_CLIENT_SECRET=change-me-inventory-secret

# --- checkin-service boarding-pass HMAC key (§5/§10) -------------------------
# Required, minimum 32 bytes, and must NOT be the old dev default - check-in
# refuses to start otherwise.  Generate with:  openssl rand -base64 32
CHECKIN_BOARDING_PASS_KEY=change-me-boarding-pass-key-at-least-32-bytes

# --- notification-service Gmail SMTP (app password, not your Gmail password;
#     see https://myaccount.google.com/apppasswords) -------------------------
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# --- Grafana admin login (http://localhost:3001) ----------------------------
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin
