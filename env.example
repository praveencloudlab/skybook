# Copy this file to .env before running `docker compose up --build`.
# .env is gitignored - never commit real secrets.

# Shared between auth-service and api-gateway - both must see the exact
# same value or every token the gateway validates will look forged.
JWT_SECRET=change-me-to-a-long-random-string

# notification-service's Gmail SMTP credentials (app password, not your
# normal Gmail password - see https://myaccount.google.com/apppasswords).
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# checkin-service's boarding-pass HMAC signing key. Optional - falls back
# to a dev-only default if unset, but override it for anything beyond
# your own local machine.
CHECKIN_BOARDING_PASS_KEY=change-me-too

# Grafana admin login (http://localhost:3001). Optional - defaults to
# admin/admin if unset.
GRAFANA_ADMIN_PASSWORD=change-me-three
